{
  "name": "@sui402/storage",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude test/integration.test.ts",
    "test:integration": "vitest run test/integration.test.ts"
  },
  "dependencies": {
    "@sui402/protocol": "0.1.0",
    "@sui402/receipts": "0.1.0",
    "@sui402/server": "0.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "pg": "^8.16.3",
    "redis": "^5.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "description": "Durable storage adapters for Sui402 challenges, payments, receipts, and replay protection.",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
