{
  "name": "@sui402/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sui402/policy": "0.1.0",
    "@sui402/protocol": "0.1.0",
    "@sui402/receipts": "0.1.0",
    "@sui402/sui": "0.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "description": "Express middleware and provider helpers for protecting HTTP routes with Sui402 payments.",
  "files": [
    "dist",
    "README.md"
