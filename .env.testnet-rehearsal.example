NODE_ENV=development
PORT=4030

SUI402_NETWORK=sui:testnet
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443
SUI402_SESSION_PACKAGE_ID=0x35265692bed3c723ca401ddb7a533ea8b35238645bdc25ecc51dea31d9062b3b
SUI402_SETTLEMENT_PACKAGE_ID=0x35265692bed3c723ca401ddb7a533ea8b35238645bdc25ecc51dea31d9062b3b

SUI402_MERCHANT_ADDRESS=0x3a887b8701c31de6b7e17356a7322391b89f449805f364ad66b51233d6e934f6
SUI402_COIN_TYPE=0x2::sui::SUI
SUI402_PRICE=1000000
SUI402_RESOURCE_SCOPE=api:market-feed
SUI402_SERVICE_NAME=sui402-testnet-rehearsal

SUI402_SESSION_ENDPOINT=http://127.0.0.1:4030/gateway/merchants/atlas-api/pay
SUI402_PAYMENT_ENDPOINT=http://127.0.0.1:4030/gateway/merchants/atlas-api/pay
SUI402_SESSION_FUNDING=10000000

SUI402_CONSOLE_STORAGE_DRIVER=file
SUI402_CONSOLE_FILE_STORE_PATH=.sui402/testnet-rehearsal-console-store.json
SUI402_CONSOLE_PROVIDER_BASE_URL=http://127.0.0.1:4030
SUI402_CONSOLE_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Optional public intake host policy for rehearsal. Leave blank for local
# experiments; set when rehearsing invite-only publisher onboarding.
SUI402_CONSOLE_PUBLIC_INTAKE_ALLOWED_HOSTS=
SUI402_CONSOLE_PUBLIC_INTAKE_BLOCKED_HOSTS=
SUI402_CONSOLE_PUBLISHER_AUTH_RATE_LIMIT_MAX=30
SUI402_CONSOLE_PUBLISHER_AUTH_RATE_LIMIT_WINDOW_MS=60000

# Direct Sui gRPC indexing into the console, including durable cursor state.
SUI402_INDEXER_SOURCE=grpc
SUI402_INDEXER_SINK=console-http
SUI402_INDEXER_CONSOLE_URL=http://127.0.0.1:4030
SUI402_INDEXER_CONSOLE_API_KEY=
SUI402_INDEXER_GRPC_START_CHECKPOINT=

# Generate with:
# $env:SUI402_RECEIPT_SIGNER_ID=$env:SUI402_MERCHANT_ADDRESS
# npm run receipt:key
# Then paste the returned env values here.
SUI402_RECEIPT_SIGNER_ID=
SUI402_RECEIPT_PRIVATE_KEY_PEM_BASE64=

# Set once `sui402-settlement create-ledger` prints a ledger id.
SUI402_SETTLEMENT_LEDGER_ID=

# Optional production-like storage once Docker/Postgres/Redis are available.
SUI402_REDIS_URL=
SUI402_POSTGRES_URL=
SUI402_CONSOLE_POSTGRES_URL=

# Optional Walrus publisher/aggregator for export smoke tests.
SUI402_WALRUS_PUBLISHER_URL=
SUI402_WALRUS_AGGREGATOR_URL=
